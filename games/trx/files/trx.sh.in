#!/bin/sh
: ${TRX_BASE:="${HOME}/.local/share/%%PORTNAME%%"}

export TRX_CONFIG_DIR="${TRX_BASE}/cfg"
export TRX_CACHE_DIR="${TRX_BASE}/cache"
export TRX_GAMES_DIR="${TRX_BASE}/games"
export TRX_SCREENSHOTS_DIR="${TRX_BASE}/screenshots"
export TRX_SAVES_DIR="${TRX_BASE}/saves"

exec %%PREFIX%%/bin/TRX.bin "$@"
